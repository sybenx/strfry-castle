# Copy to .env and fill in. See CLAUDE.md, Component 2 for details.

# Hex pubkey of the Lord. Required.
OWNER_PUBKEY=

# Name of the strfry container steward reaches via `docker exec`.
STRFRY_CONTAINER=strfry

# Comma-separated public relays used for follows/report/reaction fallback
# fetches and scribe archival.
PUBLIC_RELAYS=

# How long an Outer Lands event survives before it's eligible for purge.
OUTER_TTL_DAYS=30

# How often the cycle loop runs (follows sync, report intake,
# react-warding, ledger merge, purge-newly-banned, stats).
CYCLE_MINUTES=10

# Cron expression for automatic raids. Empty = manual raids only (the
# default — raids happen "at the Lord's pleasure").
RAID_CRON=

# Raids log what they would delete but delete nothing. Default ON for the
# first deploy; the README says review a dry-run raid's log before arming
# deletion.
RAID_DRY_RUN=true

# Invite tree limits.
MAX_INVITES=5
MAX_DEPTH=4

# Optional. Enables serving /.well-known/nostr.json mapping tree members'
# labels to their pubkeys.
NIP05_DOMAIN=

# steward's HTTP listen address (towncrier + /api + NIP-05).
LISTEN=:8787
